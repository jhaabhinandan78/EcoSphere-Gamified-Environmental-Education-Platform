<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8F4"
    android:fitsSystemWindows="true">

    <!-- Top Background -->
    <View
        android:id="@+id/darkHeaderBg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#0B3D2E"
        app:layout_constraintHeight_percent="0.5"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoleSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <!-- Icon -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#1B5E20" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Your Journey"
                android:textColor="#1C1C1C"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start your eco learning experience"
                android:textColor="#5F6368"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp"/>

            <!-- Student Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStudent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="#4CAF50"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#2E7D32"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textColor="#1B5E20"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Learn, earn EcoPoints &amp; compete"
                            android:textColor="#5F6368"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- Arrow -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#4CAF50"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Teacher Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTeacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#F9FBF9"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="#A5D6A7"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#388E3C"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher"
                            android:textColor="#2E7D32"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage students &amp; track progress"
                            android:textColor="#5F6368"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#66BB6A"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Admin (Keep hidden feel) -->
            <TextView
                android:id="@+id/tvAdminLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Platform Admin"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true"
                android:alpha="0.7"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>